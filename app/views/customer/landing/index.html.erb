<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>PUROXA WATER</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      overflow-x: hidden;
    }

    /* HERO */
    .hero-bg {
      background: linear-gradient(to bottom, #7fd3f7, #ffffff);
      position: relative;
    }

    /* 3D WATER */
    .water-wave {
      filter: drop-shadow(0 -20px 35px rgba(255,255,255,0.4));
    }

    .water-wave.depth {
      filter: blur(3px);
      opacity: 0.85;
    }

    /* CARDS */
    .service-card {
      background: white;
      border-radius: 18px;
      padding: 2.5rem 2rem;
      box-shadow: 0 25px 50px rgba(0,0,0,0.12);
      transition: all 0.3s ease;
    }

    .service-card:hover {
      transform: translateY(-12px);
    }

    .floating-water {
      animation: floatWater 4s ease-in-out infinite;
    }

    @keyframes floatWater {
      0%   { transform: translate(-50%, 0); }
      50%  { transform: translate(-50%, -20px); }
      100% { transform: translate(-50%, 0); }
    }

  </style>
</head>

<body>

<%=render 'navbar'%>
<section
  class="relative min-h-screen flex items-center justify-center text-center px-6"
  style="background-image: url('<%= image_path "fresh_water.jpg" %>');
         background-size: cover;
         background-position: center;"
>

  <!-- DARK OVERLAY -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>

  <!-- CONTENT -->
  <div class="relative z-10 max-w-3xl">

    <h1 class="text-3xl sm:text-5xl font-light text-white leading-tight hero-title">
      WE SPECIALIZE IN<br>
      <span class="font-semibold text-sky-300">PURE & MINERAL WATER</span>
    </h1>

    <p class="mt-6 text-gray-200 hero-sub">
      We provide high-quality drinking water solutions, purification technology,
      and trusted distribution for homes & businesses.
    </p>

    <a href="#services"
       class="mt-10 inline-block px-8 py-3 bg-sky-500 hover:bg-sky-600
              text-white rounded-full text-sm shadow-xl transition">
      KNOW MORE
    </a>

  </div>
</section>

<!-- SERVICES -->
<section id="services" class="py-28 bg-[#0b6fb3]">
  <h2 class="text-center text-3xl font-semibold text-white mb-20">
    OUR SERVICES
  </h2>

  <div class="max-w-7xl mx-auto grid sm:grid-cols-3 gap-12 px-6">

    <div class="service-card text-center">
      <img src="https://cdn-icons-png.flaticon.com/512/2933/2933186.png" class="mx-auto h-16 mb-6">
      <h3 class="font-semibold mb-3">Water Processing</h3>
      <p class="text-sm text-gray-600">
        Advanced purification & mineral balancing systems.
      </p>
    </div>

    <div class="service-card text-center">
      <img src="https://cdn-icons-png.flaticon.com/512/2972/2972185.png" class="mx-auto h-16 mb-6">
      <h3 class="font-semibold mb-3">Distribution Support</h3>
      <p class="text-sm text-gray-600">
        Vendor onboarding, logistics & supply chain solutions.
      </p>
    </div>

    <div class="service-card text-center">
      <img src="https://cdn-icons-png.flaticon.com/512/4285/4285632.png" class="mx-auto h-16 mb-6">
      <h3 class="font-semibold mb-3">Quality Analysis</h3>
      <p class="text-sm text-gray-600">
        Lab-tested purity & international safety standards.
      </p>
    </div>

  </div>
</section>

<!-- FOOTER -->
<footer class="py-10 text-center text-gray-500 bg-white">
  © 2025 PUROXA WATER. All rights reserved.
</footer>

<!-- GSAP -->
<script>
  gsap.registerPlugin(ScrollTrigger);

  /* HERO ZOOM */
  gsap.fromTo(".hero", 
    { scale: 1.1 },
    { scale: 1, duration: 6, ease: "power2.out" }
  );

  gsap.from(".hero-title", { opacity: 0, y: 40, duration: 1 });
  gsap.from(".hero-sub", { opacity: 0, y: 30, delay: 0.4 });

  gsap.from(".service-card", {
    scrollTrigger: { trigger: "#services", start: "top 70%" },
    opacity: 0,
    y: 80,
    stagger: 0.25
  });

  /* WATER ANIMATION */
  gsap.to(".water-wave path", {
    duration: 6,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
    attr: {
      d: "M0,150 C120,170 240,200 360,190 C480,180 600,140 720,150
          C840,160 960,180 1080,190 C1200,200 1320,180 1440,170
          L1440,320 L0,320 Z"
    }
  });
</script>