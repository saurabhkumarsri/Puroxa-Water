<!-- Signup Card -->
<div class="w-full max-w-lg bg-white/90 backdrop-blur-md p-10 rounded-3xl shadow-2xl border border-gray-200">

  <!-- Header -->
  <h1 class="text-5xl font-extrabold text-center text-cyan-700 mb-2">PUROXA</h1>
  <p class="text-center text-gray-500 mb-10">Create Shop / Customer Account</p>

  <!-- Form -->
  <%= form_with url: vendor_signup_path, method: :post, local: true do %>

    <div class="mb-4">
      <%= label_tag :shop_name, "Shop Name", class: "block text-sm text-gray-700 mb-2" %>
      <%= text_field_tag :shop_name, nil, class: "w-full px-4 py-3 border rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= label_tag :name, "Owner Name" %>
      <%= text_field_tag :name, nil, class: "w-full px-4 py-3 border rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= label_tag :email, "Email" %>
      <%= email_field_tag :email, nil, class: "w-full px-4 py-3 border rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= label_tag :mobile, "Mobile Number" %>
      <%= telephone_field_tag :mobile, nil, class: "w-full px-4 py-3 border rounded-xl" %>
    </div>

    <div class="mb-4">
      <%= label_tag :password, "Password" %>
      <%= password_field_tag :password, nil, class: "w-full px-4 py-3 border rounded-xl" %>
    </div>

    <div class="mb-6">
      <%= label_tag :address, "Shop Address" %>
      <%= text_area_tag :address, nil, rows: 3, class: "w-full px-4 py-3 border rounded-xl" %>
    </div>

    <%= submit_tag "Create Account", class: "w-full py-3 bg-cyan-500 text-white rounded-xl" %>

  <% end %>

  <div class="text-center mt-6 text-sm">
    Already have an account?
    <%= link_to "Login", vendor_login_path, class: "text-cyan-500" %>
  </div>

</div>