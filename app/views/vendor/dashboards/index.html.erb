<div class="flex w-full min-h-screen bg-[#f5f9ff]">

  <!-- SIDEBAR -->
  <aside class="w-64 bg-[#0d2c63] text-white p-6 hidden md:flex flex-col">
    <h2 class="text-2xl font-bold mb-10">Hi,Rahul 👋</h2>

    <nav class="space-y-5 text-sm">
      <a href="#" class="block hover:text-cyan-300">📊 Dashboard</a>
      <a href="#" class="block hover:text-cyan-300">📦 Orders</a>
      <a href="#" class="block hover:text-cyan-300">➕ New Order</a>
      <a href="#" class="block hover:text-cyan-300">👤 Profile</a>
      <a href="#" class="block hover:text-cyan-300">⚙️ Settings</a>
    </nav>
  </aside>

  <!-- MAIN CONTENT (FULL WIDTH) -->
  <div class="flex-1 w-full px-4 md:px-8 py-6">



    <!-- STATS (FULL WIDTH GRID) -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-10 w-full">
      
      <div class="bg-white p-6 rounded-xl shadow w-full">
        <h3 class="text-2xl font-bold">12</h3>
        <p class="text-gray-500">Total Orders</p>
      </div>

      <div class="bg-white p-6 rounded-xl shadow w-full">
        <h3 class="text-2xl font-bold text-yellow-500">2</h3>
        <p class="text-gray-500">Pending</p>
      </div>

      <div class="bg-white p-6 rounded-xl shadow w-full">
        <h3 class="text-2xl font-bold text-green-600">10</h3>
        <p class="text-gray-500">Delivered</p>
      </div>

      <div class="bg-white p-6 rounded-xl shadow w-full">
        <h3 class="text-2xl font-bold text-cyan-600">150</h3>
        <p class="text-gray-500">Reward Points</p>
      </div>

    </div>

    <!-- TABLE FULL WIDTH -->
    <div class="bg-white rounded-xl shadow p-6 w-full overflow-x-auto">
      <h2 class="text-xl font-semibold mb-4">Order History</h2>

      <table class="w-full">
        <thead>
          <tr class="border-b text-left">
            <th class="py-3">Order ID</th>
            <th>Product</th>
            <th>Qty</th>
            <th>Date</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody>
          <% orders = [
            {id: "2026001", product: "1L Bottle", qty: 10, status: "Delivered"},
            {id: "2026002", product: "20L Jar", qty: 2, status: "Pending"},
            {id: "2026003", product: "500ml", qty: 5, status: "Transit"}
          ] %>

          <% orders.each do |o| %>
            <tr class="border-b hover:bg-gray-50">
              <td class="py-3"><%= o[:id] %></td>
              <td><%= o[:product] %></td>
              <td><%= o[:qty] %></td>
              <td>April 2024</td>

              <td>
                <% if o[:status] == "Delivered" %>
                  <span class="text-green-600 font-semibold">Delivered</span>
                <% elsif o[:status] == "Pending" %>
                  <span class="text-yellow-500 font-semibold">Pending</span>
                <% else %>
                  <span class="text-blue-500 font-semibold">In Transit</span>
                <% end %>
              </td>

              <td>
                <button class="bg-[#0d2c63] text-white px-3 py-1 rounded">
                  Track
                </button>
              </td>
            </tr>
          <% end %>
        </tbody>

      </table>
    </div>

    <!-- ACTION -->
    <div class="mt-8 w-full">
      <button class="bg-green-600 text-white px-6 py-3 rounded-lg hover:scale-105 transition">
        + Create New Order
      </button>
    </div>

    <!-- PROFILE -->
    <div class="grid md:grid-cols-2 gap-6 mt-10 w-full">
      
      <div class="bg-white p-6 rounded-xl shadow w-full">
        <h3 class="font-semibold mb-3">My Profile</h3>
        <p class="text-gray-600">Edit your details & password</p>
        <button class="mt-3 bg-[#0d2c63] text-white px-4 py-2 rounded">
          Edit Profile
        </button>
      </div>

      <div class="bg-white p-6 rounded-xl shadow w-full">
        <h3 class="font-semibold mb-3">Need Help?</h3>
        <p class="text-gray-600">Contact support or FAQs</p>
        <button class="mt-3 bg-[#0d2c63] text-white px-4 py-2 rounded">
          Support
        </button>
      </div>

    </div>

  </div>
</div>