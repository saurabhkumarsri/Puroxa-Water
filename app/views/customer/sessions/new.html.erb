
<div class="min-h flex items-center justify-center bg-gradient-to-b from-cyan-50 to-gray-50 px-4">
  <div class="w-full max-w-md bg-white/90 backdrop-blur-md p-10 rounded-3xl shadow-2xl border border-gray-200">
    
    <!-- Logo / Title -->
    <h1 class="text-5xl font-extrabold text-center text-cyan-700 mb-2 drop-shadow-md">PUROXA</h1>
    <p class="text-center text-gray-500 mb-10">Pure Water. Pure Trust.</p>

    <!-- Login Form -->
    <%= form_with url: customer_login_path, method: :post, local: true do %>
      <div class="mb-6">
        <%= label_tag :login, "Email or Mobile Number", class: "block text-sm text-gray-700 mb-2" %>
        <%= text_field_tag :login, nil, placeholder: "email@example.com or 9876543210", class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-cyan-400 focus:border-transparent transition shadow-sm hover:shadow-md", required: true %>
      </div>

      <div class="mb-6">
        <%= label_tag :password, "Password", class: "block text-sm text-gray-700 mb-2" %>
        <%= password_field_tag :password, nil, placeholder: "••••••••", class: "w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-cyan-400 focus:border-transparent transition shadow-sm hover:shadow-md", required: true %>
      </div>

      <%= submit_tag "Login", class: "w-full py-3 bg-cyan-500 text-white font-bold rounded-xl shadow-lg hover:bg-cyan-600 hover:shadow-2xl transition transform hover:-translate-y-0.5" %>
    <% end %>

    <!-- Links -->
    <div class="text-center mt-6 text-sm text-gray-500">
      <%= link_to "Forgot Password?", root_path, class: "hover:text-cyan-600 transition font-medium" %>
      <span class="block mt-4">
        New customer?
        <%= link_to "Create Account", customer_signup_path, class: "text-cyan-500 hover:underline transition font-medium" %>
      </span>
    </div>
  </div>
</div>
