<header class="bg-white shadow-sm px-6 py-4 flex justify-between items-center sticky top-0 z-50">
  
  <!-- Logo -->
  <div class="text-2xl font-bold text-[#0d2c63]">
    <%= link_to "Puroxa Water", root_path %>
  </div>

  <!-- Menu -->
  <nav class="flex items-center gap-6">
    <%= link_to "Home", root_path, class: "hover:text-blue-600" %>
    <%= link_to "Products", root_path, class: "hover:text-blue-600" %>
    <%= link_to "Contact", root_path, class: "hover:text-blue-600" %>

    <%= link_to "Login", vendor_login_path,
      class: "px-4 py-2 border border-[#0d2c63] rounded-lg hover:bg-gray-100" %>

    <%= link_to "Sign up", vendor_signup_path,
      class: "px-5 py-2 bg-[#0d2c63] text-white rounded-lg shadow-md hover:scale-105 transition" %>
  </nav>

</header>