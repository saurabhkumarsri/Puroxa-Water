<div class="w-full overflow-x-hidden bg-[#f8faff] text-[#0d2c63]">

<!-- 🔥 VIDEO HERO FULL WIDTH -->
<section class="relative w-full h-[80vh] overflow-hidden">

  <video autoplay muted loop playsinline
    class="absolute top-0 left-0 w-full h-full object-cover">
    <source src="<%= asset_path 'seawater.mp4' %>" type="video/mp4">
  </video>

  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 flex flex-col items-center justify-center h-full text-white text-center px-6">
    <h1 class="text-4xl md:text-6xl font-bold mb-4">
      Pure Water. Pure Life.
    </h1>

    <p class="text-lg md:text-xl mb-6">
      Premium Drinking Water for Home, Office & Events
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <button class="bg-cyan-500 px-6 py-3 rounded-lg hover:scale-105 transition">
        Order Now
      </button>
      <button class="border border-white px-6 py-3 rounded-lg hover:bg-white hover:text-black transition">
        Become a Vendor
      </button>
    </div>
  </div>

</section>

<!-- 🔷 PRODUCTS FULL WIDTH -->
<section class="w-full px-6 md:px-16 py-16 text-center">
  <h2 class="text-3xl font-bold mb-12">Our Products</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
    
    <% products = [
      {name: "500ml Bottle", price: "₹10"},
      {name: "1 Litre Bottle", price: "₹20"},
      {name: "2 Litre Bottle", price: "₹40"},
      {name: "20 Litre Jar", price: "₹80"}
    ] %>

    <% products.each do |p| %>
      <div class="bg-white p-6 rounded-xl shadow hover:-translate-y-2 transition duration-300">
        
        <img src="<%= image_path 'bottle.png' %>" 
             class="h-44 mx-auto object-contain mb-4">

        <h3 class="font-semibold text-lg"><%= p[:name] %></h3>
        <p class="my-2 font-bold text-xl"><%= p[:price] %></p>

        <button class="bg-[#0d2c63] text-white px-4 py-2 rounded hover:scale-105 transition">
          Buy Now
        </button>
      </div>
    <% end %>

  </div>
</section>

<!-- 🔷 FEATURES -->
<section class="w-full bg-blue-50 py-16 text-center px-6 md:px-16">
  <h2 class="text-3xl font-bold mb-12">Why Choose Puroxa</h2>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
    <div class="bg-white p-6 rounded-xl shadow">💧 RO Purified</div>
    <div class="bg-white p-6 rounded-xl shadow">✅ FSSAI Certified</div>
    <div class="bg-white p-6 rounded-xl shadow">🌱 Eco Friendly</div>
    <div class="bg-white p-6 rounded-xl shadow">❄️ Fresh Taste</div>
  </div>
</section>

<!-- 🔷 VENDOR -->
<section class="w-full py-16 text-center px-6 md:px-16">
  <h2 class="text-3xl font-bold mb-6">Become a Vendor</h2>

  <p class="mb-10 text-gray-600">
    Grow your business with us & earn more profit.
  </p>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
    <div class="bg-white p-6 shadow rounded">💰 High Profit</div>
    <div class="bg-white p-6 shadow rounded">🚚 Daily Supply</div>
    <div class="bg-white p-6 shadow rounded">📈 Growth</div>
    <div class="bg-white p-6 shadow rounded">🤝 Support</div>
  </div>

  <button class="bg-green-600 text-white px-6 py-3 rounded-lg hover:scale-105 transition">
    Join Now
  </button>
</section>

<!-- 🔷 TRUST -->
<section class="w-full bg-blue-100 py-16 text-center px-6">
  <h2 class="text-2xl font-bold">Trusted by 5000+ Customers</h2>
  <p class="mt-2">⭐ 4.8 Rating | 1000+ Daily Orders</p>
</section>

<!-- 🔷 TESTIMONIAL -->
<section class="w-full py-16 text-center px-6">
  <div class="bg-blue-50 p-8 rounded-xl max-w-xl mx-auto shadow italic">
    "Best water quality and fast delivery!" — Saurabh Sri.
  </div>
</section>

</div>